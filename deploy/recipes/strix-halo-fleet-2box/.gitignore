# Runtime artifacts produced by the fleet recipe (never committed).
__pycache__/
*.pyc
.ccp-state/
.mock-router-config.yaml
*.bak
*.tmp

# Operator-local, machine-specific config — copy the committed *.example
# templates to these paths; the orchestrator sources them if present (R3/R7).
versions.env
fleet.hosts

# TLS / mTLS key + cert material generated by make-mtls-certs.sh (C1) — secret,
# never committed. Default output dir is ./mtls-certs; the PEM/CSR/serial globs
# also catch certs staged elsewhere under the recipe.
mtls-certs/
*.pem
*.csr
*.srl

# Ed25519 signing key material (keygen writes ./keys/ccp_ed25519.seed) — secret,
# never committed.
keys/
*.seed
