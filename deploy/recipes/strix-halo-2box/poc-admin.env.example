# Template for the 2-box Strix Halo (AMD) PoC dashboard admin credentials.
#
# Copy this to poc-admin.env and fill in your own values:
#   cp poc-admin.env.example poc-admin.env
#   $EDITOR poc-admin.env
#
# poc-admin.env is gitignored (real credentials); this .example is committed as
# a reference only and ships demo placeholders.
#
# Usage (on Halo-A, before bring-up):
#   set -a; source deploy/recipes/strix-halo-2box/poc-admin.env; set +a
#   HALO_B_IP=192.0.2.20 bash deploy/recipes/strix-halo-2box/client-bring-up.sh

# Dashboard login email.
DASHBOARD_ADMIN_EMAIL=admin@demo.local

# Dashboard login password (CHANGE THIS for any non-demo use).
DASHBOARD_ADMIN_PASSWORD=vllmsr-demo

# Display name shown in the dashboard.
DASHBOARD_ADMIN_NAME=Admin

# Optional: routable address of the Halo-B datacenter box (HALO_B_IP:11434).
# HALO_B_IP=192.0.2.20